# Copy this file to ".env" for local development and fill in values.
# In production (Render), these are set as environment variables in the dashboard
# (DATABASE_URL is provided by the Render Postgres database; AUTH_SECRET is auto-generated).

# Local dev uses a file-based SQLite database:
DATABASE_URL="file:./dev.db"

# Long random string used to sign login sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Local-only: where uploaded files go in development (production stores them in the DB).
UPLOAD_DIR="./uploads"
