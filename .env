# Local development environment.
# For production, switch DATABASE_URL to your Postgres connection string
# (and change provider to "postgresql" in prisma/schema.prisma), then set a
# strong AUTH_SECRET. See DEPLOY.md.

DATABASE_URL="file:./dev.db"

# Used to sign session cookies. CHANGE THIS for production (any long random string).
AUTH_SECRET="dev-only-change-me-to-a-long-random-string-please-1234567890"

# Where uploaded service-provider invoice files are stored locally.
UPLOAD_DIR="./uploads"
